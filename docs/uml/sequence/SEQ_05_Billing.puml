@startuml SEQ_05_Billing
title SEQ_05: SEQUENCE — PAYMENT WIZARD, VIETQR, THU SAU, HUY HOA DON

skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam maxMessageSize 250

actor "Benh Nhan" as BN
actor "Y ta Hanh chinh" as HC
actor "Admin" as Admin

box "Frontend my-patients" #F3F4F6
  participant "PaymentWizard.jsx" as Wizard
  participant "UnpaidInvoices.jsx" as Unpaid
  participant "billing.js hooks" as BillingApi
end box

box "Backend HealthCare" #E0F2FE
  participant "BillingController" as Controller
  participant "BillingService" as Service
  participant "VietQRService" as VietQR
  participant "AuditLogMiddleware" as AuditMw
  participant "SignalR Realtime" as Hub
end box

box "Data Persistence" #DBEAFE
  database "MySQL\nhoa_don_thanh_toan" as SQL
  database "MongoDB\nmedical_histories/audit_logs" as Mongo
end box

group #EEF2FF Step 1: Review invoice
  HC -> Wizard: Mo wizard tu Patients/Examination/UnpaidInvoices
  Wizard -> BillingApi: searchInvoices({ patient, loaiDotThu, TrangThai: chua_thu })
  BillingApi -> Controller: POST /api/billing/invoices/search
  Controller -> Service: TimKiemHoaDonAsync(filter, scope)
  Service -> SQL: SELECT invoices theo scope\nTrangThai = chua_thu/bao_luu neu filter
  SQL --> Service: invoices
  Service --> Controller: PagedResult
  Controller --> BillingApi: 200 OK
  BillingApi --> Wizard: invoice hoac fallback items
end

group #ECFDF5 Step 2a: Tien mat / ConfirmPayment
  HC -> Wizard: Chon "Tien mat"
  HC -> BN: Thu tien
  HC -> Wizard: Xac nhan thanh toan
  Wizard -> BillingApi: confirmInvoice({ PhuongThucThanhToan: tien_mat })
  BillingApi -> Controller: PUT /api/billing/invoices/{id}/confirm
  Controller -> Service: XacNhanThanhToanAsync(id, request)
  Service -> SQL: validate TrangThai in (chua_thu, bao_luu)
  Service -> SQL: UPDATE TrangThai=da_thu,\nPhuongThuc=tien_mat, SoTienPhaiTra=SoTien
  Service -> Mongo: LogEvent(patient, "thanh_toan", payload)
  AuditMw -> Mongo: audit_logs mutation
  Service -> Hub: BroadcastInvoiceChanged + DashboardToday
  Controller --> BillingApi: 200 InvoiceDto
  BillingApi --> Wizard: DONE paid
end

group #F3E8FF Step 2b: VietQR / manual confirmation
  HC -> Wizard: Chon "VietQR"
  Wizard -> BillingApi: generateVietQR({ maHoaDon, SoTien, NoiDung })
  BillingApi -> Controller: POST /api/billing/invoices/{id}/generate-qr
  Controller -> Service: LayHoaDonAsync(id)
  Service -> SQL: SELECT invoice
  Controller -> VietQR: GenerateQR(maHoaDon, soTien, noiDung)
  VietQR --> Controller: VietQR image URL/data
  Controller --> BillingApi: VietQRResponse
  BillingApi --> Wizard: Hien thi QR inline
  BN -> Wizard: Quet QR bang app ngan hang
  HC -> Wizard: Xac nhan da nhan chuyen khoan
  Wizard -> BillingApi: confirmInvoice({ PhuongThucThanhToan: vietqr, MaGiaoDich? })
  BillingApi -> Controller: PUT /api/billing/invoices/{id}/confirm
  Controller -> Service: XacNhanThanhToanAsync
  Service -> SQL: UPDATE TrangThai=da_thu,\nPhuongThuc=vietqr, MaGiaoDich?
  Service -> Mongo: LogEvent "thanh_toan"
  Service -> Hub: BroadcastInvoiceChanged + DashboardToday
  Controller --> BillingApi: 200 InvoiceDto
end

group #FEF3C7 Step 2c: Thu sau / Bao luu / Cong no
  HC -> Wizard: Chon "Thu sau"
  Wizard -> BillingApi: updateInvoiceStatus({ status: bao_luu })
  BillingApi -> Controller: PUT /api/billing/invoices/{id}/status
  Controller -> Service: CapNhatTrangThaiHoaDonAsync
  Service -> SQL: validate chua_thu -> bao_luu\nor bao_luu -> da_thu/da_huy
  Service -> SQL: UPDATE TrangThai=bao_luu
  Service -> Hub: BroadcastInvoiceChanged + DashboardToday
  Controller --> BillingApi: 200 InvoiceDto
  BillingApi --> Wizard: DONE deferred
end

group #FFE4E1 Admin-only: Huy hoa don
  Admin -> Unpaid: Click Huy hoa don
  Unpaid -> BillingApi: cancelInvoice({ LyDo })
  BillingApi -> Controller: PUT /api/billing/invoices/{id}/cancel
  Controller -> Service: HuyHoaDonAsync(id, lyDo)
  Service -> SQL: validate TrangThai == chua_thu
  alt chua_thu
    Service -> SQL: UPDATE TrangThai=da_huy,\nThoiGianHuy=now
    AuditMw -> Mongo: audit_logs mutation
    Service -> Hub: BroadcastInvoiceChanged + DashboardToday
    Controller --> BillingApi: 200 OK
  else da_thu / bao_luu / da_huy
    Controller --> BillingApi: 400 Bad Request
  end
end

note right of Service
  Source sync:
  ConfirmPayment chap nhan chua_thu hoac bao_luu.
  Cancel endpoint chi Admin/quan_tri_vien.
  Y ta HC dung PaymentWizard de thu tien hoac bao_luu.
end note

@enduml
