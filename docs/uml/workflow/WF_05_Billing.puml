@startuml WF_05_Billing
' ===========================
' WF_05: QUY TRINH THANH TOAN & VIETQR
' Bao gom: Happy path + Huy hoa don
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam linetype ortho

skinparam activityBackgroundColor #EEF2FF
skinparam activityBorderColor #4F46E5
skinparam activityDiamondBackgroundColor #F0FDFA
skinparam activityDiamondBorderColor #0D9488
skinparam noteBackgroundColor #FEFCE8
skinparam noteBorderColor #EAB308

title WF_05: Quy trinh Thanh toan (Full Flow + Cancellation)

|Y ta Hanh chinh|
start
:Tiep nhan BN thanh toan;
:Xem danh sach Hoa Don chua_thu/bao_luu;
note right
  **Cac loai HoaDon:**
  1. kham_lam_sang (phi kham)
  2. can_lam_sang (phi DV CLS)
  3. thuoc (tien thuoc)
  TrangThai:
  chua_thu = moi tao
  bao_luu = thu sau/cong no
end note

:Chon HoaDon can thanh toan;

|He Thong (System)|
:PaymentWizard Step 1: Review chi tiet & Tong tien;
:Kiem tra: HoaDon.TrangThai in (chua_thu, bao_luu)?;

if (TrangThai khong hop le?) then (Da thu / Da huy)
  :TU CHOI: Hoa don da xu ly;
  stop
else (OK)
endif

|Y ta Hanh chinh|
if (Can huy hoa don?) then (Admin huy)
  |Admin|
  :Mo UnpaidInvoices;
  :Xac nhan huy hoa don;
  |He Thong (System)|
  :PUT /api/billing/invoices/{id}/cancel;
  :Chi hop le khi chua_thu;
  :Cap nhat HoaDon.TrangThai = da_huy;
  :Ghi ThoiGianHuy + thong bao;
  note right
    Source sync:
    Cancel endpoint chi Admin/quan_tri_vien.
    Y ta HC khong goi endpoint /cancel.
  end note
  stop
else (Thanh toan)
endif

:PaymentWizard Step 2: Chon hinh thuc thanh toan;

if (Hinh thuc?) then (Thu sau)
  |He Thong (System)|
  :PUT /api/billing/invoices/{id}/status\n{ TrangThai = bao_luu };
  :Giu hoa don de thu sau;
  :Broadcast invoice/dashboard;
  stop
elseif (Hinh thuc?) then (VietQR)
  |He Thong (System)|
  :POST /generate-qr;
  :Tao ma QR dong (so tien + noi dung);
  :Hien thi QR Code tren man hinh;
  
  |Benh Nhan|
  :Mo app Ngan hang;
  :Quet ma QR & Thanh toan;
  
  |Y ta Hanh chinh|
  :Xac nhan da nhan chuyen khoan;

  |He Thong (System)|
  :PUT /confirm\n{ PhuongThuc = vietqr };
  :Cap nhat HoaDon.TrangThai = da_thu;
  :Ghi MaGiaoDich neu co;
  
else (Tien mat)
  |Y ta Hanh chinh|
  :Thu tien mat & Tra lai;
  :Bam "Xac nhan da thu";
  
  |He Thong (System)|
  :PUT /confirm\n{ PhuongThuc = tien_mat };
  :Cap nhat HoaDon.TrangThai = da_thu;
endif

|He Thong (System)|
:Sync event "thanh_toan" len MongoDB medical_histories;
:Audit middleware ghi mutation vao audit_logs;
:Cap nhat Dashboard Doanh thu (Realtime);
:In Hoa don & Phieu thu;

' === Kiem tra da thanh toan het chua ===
if (Con HoaDon chua_thu/bao_luu khac?) then (Con)
  |Y ta Hanh chinh|
  :Tiep tuc thu cac HoaDon con lai;
  detach
else (Da thu het)
  |He Thong (System)|
  :Cap nhat BenhNhan.TrangThaiHomNay = da_hoan_tat;
  :Cap nhat LuotKham.TrangThai = hoan_tat;
  :Ket thuc Luot kham;
endif

|Benh Nhan|
:Nhan Thuoc & Ra ve;
stop

@enduml
