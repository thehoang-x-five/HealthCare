@startuml WF_01_Reception
' ===========================
' WF_01: QUY TRINH TIEP DON & DIEU PHOI
' Bao gom: Happy path + Huy/BN bo ve
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam linetype ortho

skinparam activityBackgroundColor #EEF2FF
skinparam activityBorderColor #4F46E5
skinparam activityDiamondBackgroundColor #F0FDFA
skinparam activityDiamondBorderColor #0D9488
skinparam noteBackgroundColor #FEFCE8
skinparam noteBorderColor #EAB308

title WF_01: Quy trinh Tiep don & Dieu phoi (Full Flow + Cancellation)

|Benh Nhan|
start
:Den Benh vien (Dat lich / Vang lai);

|Y ta Hanh chinh|
:Tiep nhan CCCD / SDT;

|He Thong (System)|
:Tim kiem & Dong bo Lich su (SQL Index);

if (Co Lich hen truoc?) then (Co)
  :Kiem tra Phan loai den;
  note right
    **Phan loai:**
    dung_gio → Priority 20
    den_som → Priority 25
    den_muon → Priority 35
  end note
  :Cap nhat LichHen.TrangThai = da_checkin;
  :Xep hang theo Do uu tien;
else (Vang lai)
  :Tao Ho so moi (neu BN moi);
  :Tao Luot Tiep Nhan Moi;
endif

:TU DONG: Tao LuotKhamBenh (dang_thuc_hien);
:TU DONG: Tao HangDoi (cho_goi);
note right
  **Automation — Do uu tien:**
  1. Cap cuu (Priority 0)
  2. Quay lai sau CLS - service_return (10)
  3. Dat lich dung gio - appointment (20)
  4. Vang lai / Den muon - walkin (30)
end note

:TU DONG: Tao HoaDon khung (chua_thu);
note right
  **Automation:**
  Phi kham duoc them vao
  HoaDon voi TrangThai = chua_thu
  (chua thanh toan)
end note

:Broadcast "QueueUpdated" (SignalR);
:Cap nhat BenhNhan.TrangThaiHomNay = cho_tiep_nhan;

|Benh Nhan|
:Xem STT tren Bang dien tu;

' === Kiem tra BN co mat ===
|Y ta Hanh chinh|
if (BN bo ve / khong den?) then (BN bo ve)
  :Bam nut "BN bo ve";
  
  |He Thong (System)|
  :Cap nhat BenhNhan.TrangThaiHomNay = da_huy;
  :Cap nhat HangDoi.TrangThai = da_huy;
  :Cap nhat LuotKham.TrangThai = da_huy;
  :HoaDon chua_thu -> da_huy;
  :HoaDon da_thu -> bao_luu;
  :Activity tab hien luot da_huy;
  note right
    **Cleanup chain source:**
    - BenhNhan -> da_huy
    - HangDoi/LuotKham -> da_huy
    - Workflow pending -> da_huy
    - HoaDon chua_thu -> da_huy
    - HoaDon da_thu -> bao_luu
  end note
  :Broadcast "QueueUpdated" (SignalR);
  stop
else (BN co mat)
endif

stop

@enduml
