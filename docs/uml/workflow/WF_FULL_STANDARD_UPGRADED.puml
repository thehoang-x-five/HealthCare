@startuml WF_FULL_STANDARD_UPGRADED
' ===========================
' MASTER WORKFLOW: STANDARD & UPGRADED
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam linetype ortho

skinparam activityBackgroundColor #EEF2FF
skinparam activityBorderColor #4F46E5
skinparam activityDiamondBackgroundColor #F0FDFA
skinparam activityDiamondBorderColor #0D9488
skinparam noteBackgroundColor #FEFCE8
skinparam noteBorderColor #EAB308

title HEALTHCARE+ WORKFLOW (QUY TRINH TOAN TRINH)

|Benh Nhan|
|Y ta Hanh chinh|
|Y ta Lam sang|
|Bac Si|
|Y ta Can lam sang|
|Ky Thuat Vien|
|He Thong (System)|

|Benh Nhan|
start
:Den Benh vien (Dat lich truoc hoac Vang lai);

|Y ta Hanh chinh|
partition "1. TIEP DON & PHAN LUONG (UI: Patients.jsx)" {
  :Tiep nhan CCCD / SDT;
  
  |He Thong (System)|
  :Tim kiem & Dong bo Lich su;
  
  if (Co Lich Hen?) then (Co)
    :Kiem tra Check-in Dung gio;
    :Uu tien Xep hang;
  else (Vang lai)
    :Tao Luot Tiep Nhan Moi;
  endif
  
  :TU DONG: Tao Hang Doi (Queue);
  note right
    **Automation:**
    He thong tu tinh Do uu tien:
    1. Cap cuu (Emergency)
    2. Quay lai sau CLS (Return)
    3. Dat lich dung gio (Booking)
    4. Vang lai / Den muon (Walk-in)
  end note
  
  :TU DONG: Tao Hoa don Kham;
  note right
    **Automation:**
    Phi kham duoc them ngay
    vao gio thanh toan
  end note
  
  :Broadcast "QueueUpdated" (Realtime);
}

|Y ta Lam sang|
partition "2. CHUAN BI KHAM (UI: Staff.jsx)" {
  :He thong Goi Loa / Hien thi TV;
  :Do Sinh Hieu (Vitals);
  :Nhap Thong tin ban dau;
  
  |He Thong (System)|
  :Cap nhat Trang thai "Cho Kham";
  :Dong bo Sinh hieu vao Ho so (EMR);
}

|Bac Si|
partition "3. KHAM BENH (UI: Examination.jsx)" {
  :Nhan Thong bao "Benh nhan cho";
  :Moi Vao Phong;
  
  |He Thong (System)|
  :Cap nhat Trang thai "Dang Kham";
  :Hien thi Canh bao Di ung/Benh nen;
  
  |Bac Si|
  :Kham Lam Sang & Xem Lich Su;
  
  if (Can CLS?) then (Co)
    :Chi dinh Xet nghiem / Chup chieu;
    
    |He Thong (System)|
    :TU DONG: Chuyen Yeu cau sang CLS;
    :Tao Hoa don Dich vu CLS (Pending);
    :Thong bao KTV (Realtime);
    
    |Y ta Can lam sang|
    partition "4. CAN LAM SANG (UI: ClsOrders.jsx)" {
      :Nhan Yeu cau ngay lap tuc;
      :Lay Mau / Huong dan;
      
      |Ky Thuat Vien|
      :Thuc hien & Nhap Ket qua;
      
      |He Thong (System)|
      :Luu Ket qua & Highlight Bat thuong;
      note right
        **Automation:**
        So sanh Chi so voi Nguong
        -> Danh dau Do/Vang
      end note
      
      :Thong bao Bac si "Da co Ket qua";
    }
  else (Khong)
  endif
  
  |Bac Si|
  :Chan doan;
  
  if (Co Don Thuoc?) then (Co)
    :Ke Don Thuoc;
    
    |He Thong (System)|
    :TU DONG: Kiem tra Ton Kho (Transaction);
    :TU DONG: Tinh Tien Don Thuoc;
    :Thong bao Duoc si "Don thuoc moi";
    
    |Bac Si|
    :Huong dan Dung thuoc;
  else (Khong)
    :Chi dinh Loi khuyen;
  endif
  
  |He Thong (System)|
  :Luu Ho so Benh an (EMR);
  :Ket thuc Kham (Auto-Complete);
}

|Y ta Hanh chinh|
if (Co Don Thuoc?) then (Co)
  partition "5. DUOC (UI: Prescriptions.jsx)" {
    :Nhan Don Thuoc (Realtime);
    :Chuan bi Thuoc theo Don;
    :Xac nhan Phat Thuoc;
    
    |He Thong (System)|
    :Tru Ton Kho (Inventory);
    :Cap nhat Trang thai "Da Phat";
  }
else (Khong)
endif

|Y ta Hanh chinh|
partition "6. THANH TOAN (UI: Billing.jsx)" {
  :Hien thi Tong hop Hoa don
  (Kham + CLS + Thuoc);
  :Chon Phuong thuc Thanh toan;
  
  if (QR Code?) then (Co)
    |He Thong (System)|
    :Goi VietQR -> Tao QR Dong;
    :Lang nghe Webhook Ngan hang;
    :TU DONG: Xac nhan Da Thu (khi co SMS);
  else (Tien mat)
    |Y ta Hanh chinh|
    :Thu tien & Xac nhan;
  endif
  
  |He Thong (System)|
  :Ghi Log Doanh thu (Audit);
  :Cap nhat Dashboard Lanh dao (Realtime);
  :Ket thuc Luot kham;
}

|Benh Nhan|
:Nhan Thuoc & Ra ve;
stop

@enduml
