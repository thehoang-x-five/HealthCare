@startuml WF_FULL_STANDARD_UPGRADED
' ===========================
' MASTER WORKFLOW: FULL PATIENT VISIT (DAT LICH → RA VE)
' Bao gom: Happy path + Cancellation + Error handling
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam linetype ortho

skinparam activityBackgroundColor #EEF2FF
skinparam activityBorderColor #4F46E5
skinparam activityDiamondBackgroundColor #F0FDFA
skinparam activityDiamondBorderColor #0D9488
skinparam noteBackgroundColor #FEFCE8
skinparam noteBorderColor #EAB308

title HEALTHCARE+ MASTER WORKFLOW (QUY TRINH TOAN TRINH)

|Benh Nhan|
|Y ta Hanh chinh|
|Y ta Lam sang|
|Bac Si|
|Y ta Can lam sang|
|Ky Thuat Vien|
|He Thong (System)|

' ===== PHASE 0: DAT LICH HEN (MOI) =====
|Benh Nhan|
start
:Yeu cau dat lich kham;

|Y ta Hanh chinh|
partition "0. DAT LICH HEN (UI: Appointments.jsx)" {
  :Chon BN + Phong + Ngay + Gio;
  
  |He Thong (System)|
  :BE: FindConflicts (Tang 1);
  :DB: sp_BookAppointment SERIALIZABLE (Tang 2);
  note right
    **Defense in Depth:**
    Tang 1 (BE) → Nhanh, UX tot
    Tang 2 (DB) → Chong Race Condition
  end note
  
  if (Trung lich?) then (Trung)
    :Thong bao trung → chon gio khac;
    detach
  else (OK)
    :Tao LichHen (dang_cho);
    :Gui SMS/Email xac nhan;
  endif
  
  |Y ta Hanh chinh|
  if (Xac nhan lich?) then (Xac nhan)
    |He Thong (System)|
    :Cap nhat LichHen = da_xac_nhan;
  else (Huy)
    |He Thong (System)|
    :Cap nhat LichHen = da_huy;
    stop
  endif
}

' ===== PHASE 1: TIEP DON =====
|Benh Nhan|
:Den Benh vien (Ngay kham);

|Y ta Hanh chinh|
partition "1. TIEP DON & PHAN LUONG (UI: Patients.jsx)" {
  :Tiep nhan CCCD / SDT;
  
  |He Thong (System)|
  :Tim kiem & Dong bo Lich su;
  
  if (Co Lich Hen?) then (Co)
    :Check-in: da_xac_nhan → da_checkin;
    :Phan loai: dung_gio / den_som / den_muon;
    :Xep hang uu tien theo phan loai;
  else (Vang lai)
    :Tao Ho so moi (neu BN moi);
    :Tao Luot Tiep Nhan;
  endif
  
  :TU DONG: Tao LuotKham (dang_thuc_hien);
  :TU DONG: Tao HangDoi (cho_goi);
  note right
    **Priority Automation:**
    0 = Cap cuu
    10 = Quay lai sau CLS
    20 = Dat lich dung gio
    30 = Vang lai / Den muon
  end note
  
  :TU DONG: Tao HoaDon Kham (chua_thu);
  :Cap nhat BN.TrangThaiHomNay = cho_tiep_nhan;
  :Broadcast "QueueUpdated" (SignalR);
}

' === BN BO VE TAI TIEP DON ===
|Y ta Hanh chinh|
if (BN bo ve?) then (Bo ve)
  |He Thong (System)|
  :Cleanup workflow: BN -> da_huy;
  :HangDoi/LuotKham -> da_huy;
  :Phieu LS/CLS/Don chua xong -> da_huy;
  :HoaDon chua_thu -> da_huy;
  :HoaDon da_thu -> bao_luu;
  :Activity tab hien luot da_huy;
  stop
else (Co mat)
endif

' ===== PHASE 2: CHUAN BI KHAM =====
|Y ta Lam sang|
partition "2. CHUAN BI KHAM (UI: Staff.jsx)" {
  :Goi BN tu HangDoi;
  
  |He Thong (System)|
  :HangDoi = dang_goi → dang_thuc_hien;
  :Broadcast "CallPatient" (SignalR);
  
  |Y ta Lam sang|
  :Do Sinh Hieu (Mach, HA, Nhiet do);
  :Nhap vao System;
  
  |He Thong (System)|
  :Luu Sinh hieu → PhieuKham;
  :BN.TrangThaiHomNay = cho_kham;
}

' ===== PHASE 3: KHAM BENH =====
|Bac Si|
partition "3. KHAM BENH (UI: Examination.jsx)" {
  :Nhan Thong bao "BN San sang";
  :Click "Bat dau kham";
  
  |He Thong (System)|
  :PhieuKham = dang_thuc_hien;
  :BN.TrangThaiHomNay = dang_kham;
  :Hien thi Canh bao Di ung/Benh nen;
  
  |Bac Si|
  :Kham Lam Sang & Xem Lich Su;
  
  if (Can CLS?) then (Co)
    :Chi dinh Xet nghiem / Chup chieu;
    
    |He Thong (System)|
    :Tao PhieuCLS (da_lap) + ChiTietDV;
    :Tao HoaDon CLS (chua_thu);
    :Thong bao Y ta CLS + KTV (SignalR);
    :BN.TrangThaiHomNay = cho_tiep_nhan_dv;
    
    ' --- CLS SUB-PROCESS ---
    |Y ta Can lam sang|
    partition "4. CAN LAM SANG (UI: ClsOrders.jsx)" {
      :Nhan BN & Lay mau;
      
      |He Thong (System)|
      :PhieuCLS = dang_thuc_hien;
      :BN.TrangThaiHomNay = dang_kham_dv;
      
      |Ky Thuat Vien|
      :Thuc hien & Nhap Ket qua;
      
      |He Thong (System)|
      :Luu KQ & Highlight Bat thuong;
      note right
        **Automation:**
        So sanh Chi so vs Nguong
        → Do/Vang/Xanh
      end note
      
      :ChiTietDV = da_co_ket_qua;
      :PhieuCLS = da_hoan_tat;
      :Tao PhieuTongHop (da_hoan_tat);
      :BN.TrangThaiHomNay = cho_kham;
      :Tao HangDoi quay lai BS (service_return, Priority=10);
      :Broadcast "ResultAvailable" + "QueueUpdated";
    }

    |Bac Si|
    :Nhan KQ & Tiep tuc kham;
  else (Khong)
  endif
  
  |Bac Si|
  :Chan doan + Huong xu tri;
  
  |He Thong (System)|
  :PhieuKham = da_lap_chan_doan;
  
  |Bac Si|
  if (Co Don Thuoc?) then (Co)
    :Ke Don Thuoc;
    
    |He Thong (System)|
    :Tao DonThuoc (da_ke);
    :Kiem tra Ton Kho (Transaction);
    
    if (Ton kho du?) then (Du)
      :Tao HoaDon Thuoc (chua_thu);
      :Thong bao Y ta HC "Don moi" (SignalR);
    else (Thieu)
      :Canh bao het thuoc;
      |Bac Si|
      :Dieu chinh don;
      detach
    endif
    
    |Bac Si|
    :Huong dan Dung thuoc;
  else (Khong)
    :Loi khuyen dieu tri;
  endif
  
  |He Thong (System)|
  :PhieuKham = da_hoan_tat;
  :BN.TrangThaiHomNay = cho_xu_ly;
  :HangDoi = da_phuc_vu;
  :Sync event len MongoDB;
  :Broadcast "ExamFinished" + "QueueUpdated";
}

' ===== PHASE 5: DUOC =====
|Y ta Hanh chinh|
if (Co Don Thuoc?) then (Co)
  partition "5. DUOC (UI: Prescriptions.jsx)" {
    :Nhan Don Thuoc (SignalR);
    :Chuan bi Thuoc theo Don;
    :Xac nhan Phat Thuoc;
    
    |He Thong (System)|
    partition "Transaction SERIALIZABLE" {
      :Tru Ton Kho (KhoThuoc);
      :Ghi LichSuXuatKho;
      :DonThuoc = da_phat;
    }
    
    |Y ta Hanh chinh|
    :In Tem nhan & Giao thuoc;
  }
else (Khong)
endif

' ===== PHASE 6: THANH TOAN =====
|Y ta Hanh chinh|
partition "6. THANH TOAN (UI: Billing)" {
  :Xem HoaDon chua_thu/bao_luu;
  :PaymentWizard Step 1: Review chi tiet;
  :PaymentWizard Step 2: Chon phuong thuc;
  
  if (Thu sau?) then (Co)
    |He Thong (System)|
    :Cap nhat HoaDon = bao_luu;
    :Giu cong no de thu sau;
    stop
  elseif (QR Code?) then (Co)
    |He Thong (System)|
    :Goi VietQR → Tao QR Dong;
    
    |Benh Nhan|
    :Quet QR & Thanh toan;

    |Y ta Hanh chinh|
    :Xac nhan da nhan chuyen khoan;
    
    |He Thong (System)|
    :PUT /confirm PhuongThuc = vietqr;
    :HoaDon = da_thu;
  else (Tien mat)
    |Y ta Hanh chinh|
    :Thu tien & Xac nhan;
    |He Thong (System)|
    :PUT /confirm PhuongThuc = tien_mat;
    :HoaDon = da_thu;
  endif
  
  |He Thong (System)|
  :Ghi event thanh_toan vao MongoDB;
  :Audit middleware ghi mutation vao audit_logs;
  :Cap nhat Dashboard (Realtime);
  
  if (Con HoaDon chua_thu/bao_luu?) then (Con)
    :Thu tiep;
    detach
  else (Het)
    :BN.TrangThaiHomNay = da_hoan_tat;
    :LuotKham = hoan_tat;
  endif
}

|Benh Nhan|
:Nhan Thuoc & Ra ve;
stop

@enduml
