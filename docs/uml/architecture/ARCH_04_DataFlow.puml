@startuml ARCH_04_DataFlow
' ===========================
' ARCH_04: DATA FLOW DIAGRAM
' Source sync: 2026-05-02
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam linetype ortho
skinparam padding 8
skinparam margin 12
skinparam nodesep 30
skinparam ranksep 35

left to right direction

title ARCH_04: Data Flow - Luong du lieu thuc te theo source

actor "Y ta HC" as YTHC #LightBlue
actor "Y ta LS" as YTLS #LightGreen
actor "Bac si" as BS #Lavender
actor "Y ta CLS" as YTCLS #Gold
actor "KTV" as KTV #PeachPuff
actor "Admin" as Admin #LightCoral

rectangle "Frontend my-patients" as FE #E0F2FE {
  usecase "Appointments" as FEAppt
  usecase "Patients\nView + Activity + Genealogy" as FEPatients
  usecase "Examination" as FEExam
  usecase "Prescriptions" as FEPresc
  usecase "PaymentWizard\ncash/VietQR/Thu sau" as FEPay
  usecase "UnpaidInvoices" as FEUnpaid
  usecase "History/Reports/Dashboard" as FERead
  usecase "Staff/Departments/Admin" as FEAdmin
}

rectangle "API Controllers" as API #DBEAFE {
  usecase "Auth/Otp/Admin" as APIAuth
  usecase "Appointments/Patients/Genealogy/History" as APIPatient
  usecase "Queue/Clinical/CLS" as APIClinical
  usecase "Pharmacy/Billing" as APIBilling
  usecase "Dashboard/Reports/Analytics/Notifications" as APIRead
  usecase "MasterData" as APIMaster
}

rectangle "Business Services" as BL #D1FAE5 {
  usecase "AppointmentService\nsp_BookAppointment" as SvcAppt
  usecase "Patient/Genealogy/HistoryService" as SvcPatient
  usecase "Queue/Clinical/ClsService" as SvcClinical
  usecase "Pharmacy/Billing/VietQRService" as SvcBilling
  usecase "Dashboard/Report/Analytics" as SvcReport
  usecase "Admin/Master/Notification" as SvcAdmin
  usecase "OverdueWorkflowCleanup" as Cleanup
}

database "MySQL" as MySQL #FEF3C7 {
  usecase "nhan_vien_y_te\nstaff=user" as TblStaff
  usecase "benh_nhan/lich_hen" as TblPatient
  usecase "hang_doi/luot_kham\nphieu LS/CLS" as TblVisit
  usecase "don_thuoc/kho/lich_su_xuat" as TblRx
  usecase "hoa_don_thanh_toan\nchua_thu/bao_luu/da_thu/da_huy" as TblInvoice
}

database "MongoDB" as MongoDB #CFFAFE {
  usecase "medical_histories\nclinical/payment events" as CollMed
  usecase "audit_logs\nmutation audit" as CollAudit
}

cloud "External/Realtime" as Ext #FCE7F3 {
  usecase "SignalR RealtimeHub" as SignalR
  usecase "VietQR image URL" as VietQR
}

YTHC --> FEAppt
YTHC --> FEPatients
YTHC --> FEPay
YTHC --> FEPresc
YTHC --> FERead
BS --> FEExam
BS --> FEPresc
YTLS --> FEExam
YTCLS --> FEExam
KTV --> FEExam
Admin --> FEAdmin
Admin --> FEUnpaid
Admin --> FERead

FEAppt --> APIPatient
FEPatients --> APIPatient
FEExam --> APIClinical
FEPresc --> APIBilling
FEPay --> APIBilling
FEUnpaid --> APIBilling
FERead --> APIRead
FEAdmin --> APIAuth
FEAdmin --> APIMaster

APIPatient --> SvcAppt
APIPatient --> SvcPatient
APIClinical --> SvcClinical
APIBilling --> SvcBilling
APIRead --> SvcReport
APIAuth --> SvcAdmin
APIMaster --> SvcAdmin

SvcAppt --> TblPatient : lich_hen\nSERIALIZABLE procedure
SvcPatient --> TblPatient : patient + genealogy MaCha/MaMe
SvcClinical --> TblVisit : queue/visit/exam/cls/status
SvcClinical --> CollMed : kham_lam_sang/xet_nghiem events
SvcBilling --> TblRx : prescribe/dispense/stock log
SvcBilling --> TblInvoice : invoice create/status/confirm
SvcBilling --> CollMed : event thanh_toan
SvcBilling --> VietQR : generate QR
SvcReport --> TblVisit
SvcReport --> TblInvoice
SvcReport --> CollMed : analytics aggregation
SvcAdmin --> TblStaff
Cleanup --> TblVisit : stale workflow -> da_huy
Cleanup --> TblInvoice : chua_thu -> da_huy\nda_thu -> bao_luu

SvcClinical --> SignalR : QueueUpdated/ResultAvailable
SvcBilling --> SignalR : InvoiceChanged/DashboardToday
SvcAdmin --> SignalR : notifications

APIAuth ..> CollAudit : AuditLogMiddleware
APIPatient ..> CollAudit
APIClinical ..> CollAudit
APIBilling ..> CollAudit
APIMaster ..> CollAudit

note bottom of FEPay
  PaymentWizard:
  REVIEW -> METHOD -> CONFIRM -> DONE
  Method: tien_mat, vietqr, Thu sau.
  Thu sau = bao_luu/cong no.
end note

note bottom of FEPatients
  Tab Hoat dong:
  - Mongo medical_histories
  - SQL visits da_huy/qua han
  de phan biet completed vs cancelled.
end note

@enduml
