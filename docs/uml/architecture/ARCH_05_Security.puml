@startuml ARCH_05_Security
' ===========================
' ARCH_05: SECURITY / RBAC ARCHITECTURE
' Source sync: 2026-05-02
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam shadowing false

title ARCH_05: Bao mat, RBAC va Data Scope

left to right direction

rectangle "Frontend my-patients" as FE #E0F2FE {
  component "Auth Store\naccessToken + user" as AuthStore
  component "ProtectedRoute.jsx" as ProtectedRoute
  component "Sidebar.jsx" as Sidebar
  component "permissions.js\nisAdmin/isReceptionNurse\ncanManageReception\ncanEnterClsResult" as Permissions
  component "PaymentWizard.jsx\nrole guard canPay" as PayGuard
}

rectangle "ASP.NET Core API" as API #DBEAFE {
  component "[Authorize]\nJWT Bearer" as Authorize
  component "RequireRoleAttribute" as RequireRole
  component "RequireNurseTypeAttribute" as RequireNurseType
  component "UserScopeContext\nVaiTro + loai_y_ta + ma_khoa" as Scope
  component "DataScopeExtensions\nScopedPatientIdsByDepartment" as DataScope
  component "AuditLogMiddleware\nPOST/PUT/DELETE" as AuditMw
}

rectangle "Auth Model" as AuthModel #D1FAE5 {
  component "NhanVienYTe = staff = user\nTenDangNhap/MatKhauHash\nVaiTro/LoaiYTa/MaKhoa\nTrangThaiTaiKhoan" as StaffUser
  component "RefreshToken table\nrotation/revoke" as RefreshToken
  component "OTP change password" as Otp
  component "Admin staff API\nlock/unlock/reset password" as AdminApi
}

database "MySQL" as SQL #FEF3C7 {
  component "nhan_vien_y_te" as TblStaff
  component "refresh_tokens" as TblRefresh
  component "domain tables\npatients/visits/invoices" as DomainTables
}

database "MongoDB" as Mongo #F5F3FF {
  component "audit_logs\nTTL 365 ngay" as AuditLogs
  component "medical_histories\nclinical/payment events" as MedicalHistories
}

AuthStore --> ProtectedRoute
ProtectedRoute --> Permissions
Sidebar --> Permissions
PayGuard --> Permissions
Permissions ..> Scope : same role contract

ProtectedRoute --> Authorize : REST/JSON + Bearer
Authorize --> RequireRole
RequireRole --> RequireNurseType
Authorize --> Scope
Scope --> DataScope

StaffUser --> TblStaff
RefreshToken --> TblRefresh
Otp --> TblStaff
AdminApi --> StaffUser

DataScope --> DomainTables
AuditMw --> AuditLogs
Authorize --> TblStaff : login/status check
MedicalHistories ..> DomainTables : logical patient/visit ids

note right of Scope
  Global:
  - admin / quan_tri_vien
  - y_ta + hanhchinh

  Department scope:
  - bac_si
  - y_ta + ls/phong_kham
  - y_ta + cls/can_lam_sang
  - ky_thuat_vien
end note

note bottom of RequireNurseType
  Attribute bo qua check LoaiYTa
  neu user khong phai y_ta.
  Nurse aliases:
  hanhchinh, phong_kham/ls,
  can_lam_sang/cls.
end note

note bottom of AuditMw
  Audit logs dung MongoDB de ghi mutation.
  Medical history events khac audit:
  kham_lam_sang, xet_nghiem,
  don_thuoc, thanh_toan.
end note

@enduml
