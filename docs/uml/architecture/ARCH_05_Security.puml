@startuml ARCH_05_Security
' ===========================
' ARCH_05: SECURITY ARCHITECTURE
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam linetype ortho

title ARCH_05: Kien truc Bao mat (Security Architecture)

' ===========================
' CLIENT
' ===========================
rectangle "Client Layer" as Client #E0F2FE {
  rectangle "Browser" as Browser {
    [HTTPS Only] as HTTPS
    [HttpOnly Cookies] as HttpOnly
    [CORS Policy] as CORS
    [XSS Protection] as XSS
  }
}

' ===========================
' API GATEWAY
' ===========================
rectangle "API Gateway" as APIGateway #DBEAFE {
  rectangle "Security Middleware" as SecMW {
    [Rate Limiting] as RateLimit
    [IP Whitelist] as IPWhite
    [Request Validation] as ReqVal
    [CORS Middleware] as CORSMw
  }
  
  rectangle "Authentication" as AuthLayer {
    [JWT Bearer Auth] as JWTAuth
    [Token Validation] as TokenVal
    [Role-Based Auth] as RoleAuth
  }
  
  rectangle "Authorization" as AuthzLayer {
    [[Authorize] Attribute] as AuthzAttr
    [Policy-Based Auth] as PolicyAuth
    [Resource-Based Auth] as ResAuth
  }
}

' ===========================
' JWT TOKEN FLOW
' ===========================
rectangle "JWT Token Management" as JWTMgmt #D1FAE5 {
  rectangle "Access Token" as AccessToken {
    [Short-lived (15 min)] as ATShort
    [Contains: UserId, Role] as ATClaims
    [Stored in Memory] as ATMem
  }
  
  rectangle "Refresh Token" as RefreshToken {
    [Long-lived (7 days)] as RTLong
    [HttpOnly Cookie] as RTCookie
    [Stored in DB] as RTDB
    [Rotation on Use] as RTRotate
  }
  
  rectangle "Token Operations" as TokenOps {
    [Generate Token] as GenToken
    [Validate Token] as ValToken
    [Refresh Token] as RefToken
    [Revoke Token] as RevToken
    [Blacklist Token] as BlackToken
  }
}

' ===========================
' PASSWORD SECURITY
' ===========================
rectangle "Password Security" as PwdSec #FEF3C7 {
  [BCrypt Hashing] as BCrypt
  [Salt: 12 rounds] as Salt
  [Password Policy] as PwdPolicy
  [Brute Force Protection] as BruteForce
  [Account Lockout] as Lockout
}

' ===========================
' DATA PROTECTION
' ===========================
rectangle "Data Protection" as DataProt #FCE7F3 {
  rectangle "At Rest" as AtRest {
    [MySQL Encryption] as MySQLEnc
    [MongoDB Encryption] as MongoEnc
    [Backup Encryption] as BackupEnc
  }
  
  rectangle "In Transit" as InTransit {
    [TLS 1.3] as TLS
    [Certificate Pinning] as CertPin
  }
  



' ===========================
' AUDIT & LOGGING
' ===========================
rectangle "Audit & Logging (MongoDB)" as Audit #F5F3FF {
  [User Actions (Login/Out)] as UserAudit
  [Data Changes (Create/Update/Delete)] as DataAudit
  [Access Tracking] as AccessAudit
}

' ===========================
' CONNECTIONS
' ===========================
Browser --> HTTPS
HTTPS --> RateLimit
RateLimit --> CORSMw
CORSMw --> JWTAuth

JWTAuth --> TokenVal
TokenVal --> AccessToken
TokenVal --> RefreshToken

JWTAuth --> RoleAuth
RoleAuth --> AuthzAttr
AuthzAttr --> PolicyAuth

GenToken --> BCrypt
BCrypt --> Salt



' ===========================
' NOTES
' ===========================
note right of AccessToken
  JWT Payload:
  {
    "sub": "NV001",
    "role": "BacSi",
    "ma_khoa": "KH001",
    "exp": 1735689600,
    "iat": 1735688700
  }
end note

note right of PwdPolicy
  Password Policy:
  - Min 8 characters
  - 1 uppercase
  - 1 lowercase
  - 1 number
  - 1 special char
end note

note right of Lockout
  Account Lockout:
  - 5 failed attempts
  - Lock 15 minutes
  - Log security event
end note

note bottom of Audit
  Audit Log stored in MongoDB:
  {
    action: "LOGIN",
    user_id: "NV001",
    ip: "192.168.1.100",
    timestamp: ISODate(),
    status: "SUCCESS"
  }
end note

note bottom of DataProt
  HIPAA/GDPR Compliance:
  - PII masking (phone: ***123)
  - Access control
  - Right to be forgotten
  - Data retention policy
end note

@enduml
