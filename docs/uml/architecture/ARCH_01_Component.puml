@startuml ARCH_01_Component
' ===========================
' ARCH_01: SO DO THANH PHAN 
' ===========================
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam padding 8
skinparam margin 12
skinparam nodesep 30
skinparam ranksep 35

left to right direction

title ARCH_01: So do Thanh phan

' ===========================
' PRESENTATION LAYER
' ===========================
package "Presentation Layer" as PL #E0F2FE {

  component "React SPA (Vite)" as FE

  component "Routes\n- Login/Overview\n- Patients + Activity\n- Appointments\n- Examination/CLS\n- Prescriptions\n- UnpaidInvoices\n- History/Reports\n- Staff/Departments\n- Notifications/Settings" as FE_Pages

  component "UI Components\n- Sidebar/ProtectedRoute\n- PaymentWizard/VietQRDisplay\n- PatientTimeline/Activity\n- Tables/Forms/Toast" as FE_UI

  component "Hooks/API clients\n- auth/admin/billing\n- patients/history/genealogy\n- queue/examination/cls\n- pharmacy/reports/notifications" as FE_Hooks

  component "Frontend Guards\npermissions.js\nTAB_VISIBILITY\ncanManageReception\ncanEnterClsResult" as FE_Guards

  component "Store\nZustand auth/UI\nReact Query cache\nSignalR subscriptions" as FE_Store

  FE --> FE_Pages
  FE --> FE_UI
  FE --> FE_Hooks
  FE --> FE_Guards
  FE_Hooks --> FE_Store
}

' ===========================
' API LAYER
' ===========================
package "API Layer (ASP.NET Core)" as AL #DBEAFE {

  component "Controllers\n- Auth/Otp/Admin\n- Patients/Genealogy/History\n- Appointments/Queue/Clinical/CLS\n- Pharmacy/Billing/VietQR\n- Dashboard/Reports/Analytics\n- Notifications/MasterData" as API_Ctrls

  component "Middleware/Attributes\n- JwtAuth\n- AuditLogMiddleware\n- RequireRole\n- RequireNurseType\n- CORS" as API_MW

  component "SignalR\nRealtimeHub\nRealtimeService" as API_Hubs

  component "DTOs\n- Request DTOs\n- Response DTOs" as API_DTO

  API_MW --> API_Ctrls
  API_Ctrls --> API_DTO
}

' ===========================
' BUSINESS LAYER
' ===========================
package "Business Layer" as BL #D1FAE5 {

  component "Service Interfaces\n- Auth/Patient/Appointment\n- Queue/Clinical/CLS\n- Pharmacy/Billing\n- Dashboard/Reports/Analytics\n- Admin/Notifications" as SVC_I

  component "Service Implementations\n- AuthService/AdminService\n- Patient/Genealogy/History\n- Queue/Clinical/Cls\n- Pharmacy/Billing/VietQR\n- Dashboard/Analytics/Report\n- OverdueWorkflowCleanup" as SVC_Impl

  component "Workflow Guards\n- status transitions\n- payment transitions\n- data scope by MaKhoa\n- overdue cleanup" as BL_Val

  component "DTO Mapping\nmanual mappers\nFE contract adapters" as BL_Map

  SVC_I <|.. SVC_Impl
  SVC_Impl --> BL_Val
  SVC_Impl --> BL_Map
}

' ===========================
' DATA ACCESS LAYER
' ===========================
package "Data Access Layer" as DAL #FEF3C7 {

  component "EF Core (MySQL)\n- DataContext\n- Repositories (IRepository<T>)\n- Entities/Configurations" as DAL_EF

  component "MongoDB Driver\n- MongoDbContext\n- medical_histories\n- audit_logs\n- aggregation analytics" as DAL_Mongo
}

' ===========================
' CONNECTIONS (clean & readable)
' ===========================
FE_Hooks --> API_Ctrls : REST/JSON
FE_Store --> API_Hubs  : SignalR
FE_Guards ..> API_MW : same RBAC contract

API_Ctrls --> SVC_I
API_Hubs  --> SVC_I

SVC_Impl --> DAL_EF
SVC_Impl --> DAL_Mongo

@enduml
